// Okave Platform - Prisma Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  AGENT
  FARMER
  BUYER
  COOP_ADMIN
  ADMIN
}

enum BuyerType {
  HOUSEHOLD
  VENDOR
  RESTAURANT
  RETAILER
}

enum ListingStatus {
  DRAFT
  LIVE
  RESERVED
  SOLD
  CANCELLED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum NotificationChannel {
  SMS
  EMAIL
  PUSH
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
}

enum Frequency {
  WEEKLY
  MONTHLY
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  phone         String?  @unique
  password_hash String
  role          Role
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  buyer_profile    BuyerProfile?
  notifications    Notification[]  @relation("UserNotifications")
  listings_created ProduceListing[] @relation("AgentListings")
  listing_photos   ListingPhoto[]
}

model Coop {
  id                  String   @id @default(cuid())
  name                String
  location            String?
  contact_person_name String?
  contact_phone       String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  members  CoopMember[]
  farmers  FarmerProfile[]
  listings ProduceListing[]
  orders   Order[]
}

model FarmerProfile {
  id                        String   @id @default(cuid())
  user_id                   String?  @unique
  full_name                 String
  phone                     String
  state                     String   @default("")
  lga                       String   @default("")
  community                 String   @default("")
  coop_id                   String?
  preferred_contact_channel String   @default("SMS")
  main_crops                String[]
  registered_by_agent_id    String?
  created_at                DateTime @default(now())
  updated_at                DateTime @updatedAt

  coop          Coop?            @relation(fields: [coop_id], references: [id])
  listings      ProduceListing[] @relation("FarmerListings")
  coop_members  CoopMember[]
  notifications Notification[]   @relation("FarmerNotifications")
}

model CoopMember {
  id        String   @id @default(cuid())
  coop_id   String
  farmer_id String
  joined_at DateTime @default(now())

  coop   Coop          @relation(fields: [coop_id], references: [id])
  farmer FarmerProfile @relation(fields: [farmer_id], references: [id])

  @@unique([coop_id, farmer_id])
}

model BuyerProfile {
  id         String    @id @default(cuid())
  user_id    String    @unique
  buyer_type BuyerType @default(HOUSEHOLD)
  address    String?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  user          User              @relation(fields: [user_id], references: [id])
  orders        Order[]
  subscriptions SubscriptionPlan[]
}

model ProduceListing {
  id                           String        @id @default(cuid())
  farmer_id                    String?
  coop_id                      String?
  agent_id                     String
  crop_type                    String
  variety                      String        @default("")
  quantity                     Float
  unit                         String
  location                     String        @default("")
  harvest_date                 DateTime?
  base_price_per_unit          Float
  suggested_min_price_per_unit Float?
  suggested_max_price_per_unit Float?
  final_price_per_unit         Float
  status                       ListingStatus @default(DRAFT)
  quality_grade                String?
  quality_verified_by_agent    Boolean       @default(false)
  quality_notes                String        @default("")
  created_at                   DateTime      @default(now())
  updated_at                   DateTime      @updatedAt

  farmer FarmerProfile?  @relation("FarmerListings", fields: [farmer_id], references: [id])
  coop   Coop?           @relation(fields: [coop_id], references: [id])
  agent  User            @relation("AgentListings", fields: [agent_id], references: [id])
  photos ListingPhoto[]
  orders Order[]
}

model MarketPriceSnapshot {
  id                     String   @id @default(cuid())
  crop_type              String
  unit                   String
  market_location        String
  min_price_per_unit     Float
  max_price_per_unit     Float
  average_price_per_unit Float
  source                 String   @default("manual_entry")
  recorded_at            DateTime @default(now())
}

model ListingPhoto {
  id               String   @id @default(cuid())
  listing_id       String
  url              String
  taken_by_user_id String
  created_at       DateTime @default(now())

  listing ProduceListing @relation(fields: [listing_id], references: [id])
  user    User           @relation(fields: [taken_by_user_id], references: [id])
}

model Order {
  id               String        @id @default(cuid())
  buyer_id         String
  listing_id       String
  coop_id          String?
  quantity         Float
  price_per_unit   Float
  total_amount     Float
  status           OrderStatus   @default(PENDING)
  payment_status   PaymentStatus @default(UNPAID)
  delivery_address String
  delivery_date    DateTime?
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt

  buyer   BuyerProfile   @relation(fields: [buyer_id], references: [id])
  listing ProduceListing @relation(fields: [listing_id], references: [id])
  coop    Coop?          @relation(fields: [coop_id], references: [id])
  payment Payment?
}

model Payment {
  id              String    @id @default(cuid())
  order_id        String    @unique
  amount          Float
  payment_method  String    @default("SIMULATED")
  transaction_ref String
  status          String    @default("PENDING")
  paid_at         DateTime?

  order Order @relation(fields: [order_id], references: [id])
}

model SubscriptionPlan {
  id                 String    @id @default(cuid())
  buyer_id           String
  label              String
  frequency          Frequency @default(WEEKLY)
  next_delivery_date DateTime?
  is_active          Boolean   @default(true)
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  buyer BuyerProfile      @relation(fields: [buyer_id], references: [id])
  items SubscriptionItem[]
}

model SubscriptionItem {
  id              String @id @default(cuid())
  subscription_id String
  crop_type       String
  quantity        Float
  unit            String

  subscription SubscriptionPlan @relation(fields: [subscription_id], references: [id])
}

model Notification {
  id         String              @id @default(cuid())
  user_id    String?
  farmer_id  String?
  channel    NotificationChannel @default(SMS)
  message    String
  status     NotificationStatus  @default(QUEUED)
  created_at DateTime            @default(now())
  sent_at    DateTime?

  user   User?          @relation("UserNotifications", fields: [user_id], references: [id])
  farmer FarmerProfile? @relation("FarmerNotifications", fields: [farmer_id], references: [id])
}
